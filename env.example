# PostgreSQL connection string
DATABASE_URL="postgresql://user:password@localhost:5432/database_name"

# NextAuth secret — generate with: openssl rand -base64 32
AUTH_SECRET="secret"

# Google OAuth credentials (https://console.cloud.google.com)
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# SMS provider: mock | twilio | msg91 | fast2sms | aws_sns
# When "mock", the OTP is echoed back in the send-otp API response/UI since
# no real SMS goes out. Switch to a real provider before going live.
SMS_PROVIDER=mock

GEMINI_API_KEY=""

# Razorpay (https://dashboard.razorpay.com/app/keys)
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
